# En production : surcharger via .env.local (jamais commité — voir .gitignore)

###> symfony/framework-bundle ###
APP_ENV=dev
# Générer un vrai secret : php -r "echo bin2hex(random_bytes(16));"
APP_SECRET=CHANGE-ME-32-hex-chars
###< symfony/framework-bundle ###

###> symfony/routing ###
# Configure how to generate URLs in non-HTTP contexts, such as CLI commands.
# See https://symfony.com/doc/current/routing.html#generating-urls-in-commands
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> symfony/mailer ###
# En dev : null://null n'envoie rien (les mails sont juste loggés).
# En prod : smtp sur ssl0.ovh.net:465 avec une boîte mail OVH dédiée (voir DEPLOY.md)
MAILER_DSN=null://null
###< symfony/mailer ###

# L'adresse de destination ne vit QU'ICI, côté serveur — jamais dans le HTML public.
CONTACT_TO=contact@groupe-horao.com
CONTACT_FROM=no-reply@groupe-horao.com

###> doctrine/doctrine-bundle ###
# En dev : PostgreSQL local (docker compose up -d si tu utilises compose.yaml).
# En prod : DSN de la Web Cloud Database OVH (postgresql-xxx.database.cloud.ovh.net).
DATABASE_URL="postgresql://app:!ChangeMe!@127.0.0.1:5432/groupe_horao?serverVersion=16&charset=utf8"
###< doctrine/doctrine-bundle ###
