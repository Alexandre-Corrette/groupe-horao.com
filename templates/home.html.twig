{% extends 'base.html.twig' %}

{% block title %}Groupe Horao — Immobilier, événementiel, restauration & technologies{% endblock %}

{% block meta %}
<meta name="description" content="Groupe Horao, groupe indépendant multi-activités : immobilier, événementiel, restauration et technologies — dont Mercure-IA, l'intelligence artificielle souveraine du secteur CHR.">
<meta name="robots" content="index, follow, max-image-preview:large">
<link rel="canonical" href="https://groupe-horao.com/">
<meta property="og:type" content="website">
<meta property="og:locale" content="fr_FR">
<meta property="og:site_name" content="Groupe Horao">
<meta property="og:url" content="https://groupe-horao.com/">
<meta property="og:title" content="Groupe Horao — Immobilier, événementiel, restauration & technologies">
<meta property="og:description" content="Un groupe indépendant, quatre pôles d'activité — et Mercure-IA, l'intelligence artificielle souveraine de l'hôtellerie-restauration.">
<meta property="og:image" content="https://groupe-horao.com/images/og-groupe-horao.png">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta property="og:image:alt" content="Groupe Horao — immobilier, événementiel, restauration et technologies">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="Groupe Horao — Immobilier, événementiel, restauration & technologies">
<meta name="twitter:description" content="Un groupe indépendant, quatre pôles d'activité — et Mercure-IA, l'IA souveraine du CHR.">
<meta name="twitter:image" content="https://groupe-horao.com/images/og-groupe-horao.png">
{% endblock %}

{% block structured_data %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://groupe-horao.com/#organization",
      "name": "Groupe Horao",
      "url": "https://groupe-horao.com/",
      "email": "contact@groupe-horao.com",
      "description": "Groupe indépendant multi-activités : immobilier, événementiel, restauration et technologies. Éditeur de Mercure-IA, l'intelligence artificielle souveraine du secteur hôtellerie-restauration.",
      "knowsAbout": ["Immobilier", "Événementiel", "Restauration", "Intelligence artificielle", "Hôtellerie-restauration"]
    },
    {
      "@type": "WebSite",
      "@id": "https://groupe-horao.com/#website",
      "url": "https://groupe-horao.com/",
      "name": "Groupe Horao",
      "inLanguage": "fr-FR",
      "publisher": { "@id": "https://groupe-horao.com/#organization" }
    }
  ]
}
</script>
{% endblock %}

{% block body %}
<header>
  <div class="wrap nav">
    <div class="logo">Groupe <span>Horao</span></div>
    <nav>
      <ul>
        <li class="hide-m"><a href="#activites">Nos activités</a></li>
        <li class="hide-m"><a href="#vision">Notre vision</a></li>
        <li class="hide-m"><a href="{{ path('app_landing') }}">Mercure-IA</a></li>
        <li><a class="btn btn-primary" href="{{ path('app_landing') }}#contact">Nous contacter</a></li>
      </ul>
    </nav>
  </div>
</header>

<section class="hero">
  <div class="wrap">
    <span class="kicker">Groupe indépendant · Quatre pôles d'activité</span>
    <h1>Des lieux qui rassemblent, des outils qui font avancer : <em>bienvenue chez Groupe Horao</em>.</h1>
    <p class="sub">Immobilier, événementiel, restauration et technologies : un groupe à taille humaine qui investit dans des activités concrètes — et qui construit les outils numériques de son secteur.</p>
    <div class="hero-cta">
      <a class="btn btn-primary" href="#activites">Découvrir nos activités</a>
      <a class="btn btn-ghost" href="{{ path('app_landing') }}">Mercure-IA, notre produit phare</a>
    </div>
  </div>
</section>

<section id="activites" class="alt">
  <div class="wrap">
    <div class="sec-head center">
      <div class="eyebrow">Nos activités</div>
      <h2>Quatre pôles complémentaires, un même terrain : l'accueil et l'expérience.</h2>
      <p>De la pierre à l'assiette, de l'événement au logiciel — nos activités se nourrissent les unes les autres.</p>
    </div>
    <div class="grid-4">
      <div class="card flagship">
        <div class="ico">◈</div>
        <h3>Technologies</h3>
        <p>Nous concevons <strong>Mercure-IA</strong>, l'intelligence artificielle souveraine des dirigeants de l'hôtellerie-restauration : des réponses métier, sans que les données ne quittent l'entreprise.</p>
        <a class="more" href="{{ path('app_landing') }}">Découvrir Mercure-IA →</a>
      </div>
      <div class="card">
        <div class="ico">◍</div>
        <h3>Restauration</h3>
        <p>Restaurants et guinguettes de caractère : des lieux de vie où la cuisine rencontre la convivialité, portés par des équipes passionnées.</p>
      </div>
      <div class="card">
        <div class="ico">◎</div>
        <h3>Immobilier</h3>
        <p>Acquisition et valorisation de patrimoine : des murs choisis avec soin, pensés pour accueillir des projets durables.</p>
      </div>
      <div class="card">
        <div class="ico">✦</div>
        <h3>Événementiel</h3>
        <p>Réceptions, événements privés et professionnels : nous créons des moments qui marquent, dans des cadres qui s'y prêtent.</p>
      </div>
    </div>
  </div>
</section>

<section id="vision">
  <div class="wrap">
    <div class="sec-head">
      <div class="eyebrow">Notre vision</div>
      <h2>L'expérience du terrain, la maîtrise de la technologie.</h2>
    </div>
    <div class="values">
      <div class="card">
        <div class="ico">1</div>
        <h3>Ancrés dans le réel</h3>
        <p>Nos établissements et nos lieux sont notre terrain d'apprentissage quotidien : nous connaissons les métiers de l'accueil parce que nous les exerçons.</p>
      </div>
      <div class="card">
        <div class="ico">2</div>
        <h3>Indépendants et durables</h3>
        <p>Un développement patient, financé par nos activités, au service de projets qui durent — pas de croissance à tout prix.</p>
      </div>
      <div class="card">
        <div class="ico">3</div>
        <h3>Souverains sur nos données</h3>
        <p>Ce que nous appliquons à nos outils, nous le proposons au secteur : une technologie qui respecte la confidentialité des entreprises qui l'utilisent.</p>
      </div>
    </div>
  </div>
</section>

<section class="alt">
  <div class="wrap">
    <div class="cta-band">
      <div>
        <h3>Un projet, une question, un partenariat ?</h3>
        <p>Dirigeant CHR intéressé par Mercure-IA, partenaire data, investisseur ou porteur de projet : écrivez-nous, nous répondons vite.</p>
      </div>
      <a class="btn" href="{{ path('app_landing') }}#contact">Nous écrire</a>
    </div>
  </div>
</section>

<footer>
  <div class="wrap foot">
    <div>© 2026 Groupe Horao — Immobilier · Événementiel · Restauration · Technologies</div>
    <div>
      <a href="{{ path('app_landing') }}">Mercure-IA</a>
      &nbsp;·&nbsp;
      <a href="{{ path('app_landing') }}#contact">Contact</a>
    </div>
  </div>
</footer>
{% endblock %}
