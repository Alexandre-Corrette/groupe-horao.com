<style>
  :root{
    --ink:#0f172a;
    --ink-2:#475569;
    --ink-3:#94a3b8;
    --surface:#ffffff;
    --surface-2:#f8fafc;
    --line:#e2e8f0;
    --accent:#3730a3;
    --accent-soft:#eef2ff;
    --accent-line:#c7d2fe;
    --gold:#92400e;
    --gold-soft:#fffbeb;
    --radius:14px;
    --maxw:1080px;
  }
  *{box-sizing:border-box;margin:0;padding:0}
  html{scroll-behavior:smooth}
  body{
    font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,"Helvetica Neue",Arial,sans-serif;
    color:var(--ink);background:var(--surface);
    line-height:1.6;font-size:17px;
    -webkit-font-smoothing:antialiased;
  }
  a{color:var(--accent);text-decoration:none}
  .wrap{max-width:var(--maxw);margin:0 auto;padding:0 24px}

  /* ---------- Nav ---------- */
  header{
    position:sticky;top:0;z-index:50;
    background:rgba(255,255,255,.85);backdrop-filter:blur(10px);
    border-bottom:1px solid var(--line);
  }
  .nav{display:flex;align-items:center;justify-content:space-between;height:64px}
  .logo{font-weight:800;font-size:1.15rem;letter-spacing:-.02em;color:var(--ink)}
  .logo span{color:var(--accent)}
  nav ul{display:flex;gap:28px;list-style:none;align-items:center}
  nav a{color:var(--ink-2);font-size:.92rem;font-weight:500}
  nav a:hover{color:var(--ink)}
  .btn{
    display:inline-block;padding:10px 20px;border-radius:10px;
    font-weight:600;font-size:.95rem;transition:transform .15s ease,box-shadow .15s ease;
  }
  .btn-primary{background:var(--accent);color:#fff}
  .btn-primary:hover{transform:translateY(-1px);box-shadow:0 6px 18px rgba(55,48,163,.25)}
  .btn-ghost{border:1px solid var(--line);color:var(--ink)}
  .btn-ghost:hover{border-color:var(--accent-line);background:var(--accent-soft)}
  @media(max-width:760px){nav ul li.hide-m{display:none}}

  /* ---------- Hero ---------- */
  .hero{padding:96px 0 72px;text-align:center;background:
    radial-gradient(60% 50% at 50% 0%,var(--accent-soft) 0%,transparent 70%)}
  .kicker{
    display:inline-block;padding:5px 14px;border-radius:999px;
    background:var(--accent-soft);border:1px solid var(--accent-line);
    color:var(--accent);font-size:.8rem;font-weight:600;letter-spacing:.03em;
    margin-bottom:22px;
  }
  h1{font-size:clamp(2.1rem,5vw,3.3rem);line-height:1.12;letter-spacing:-.03em;font-weight:800;max-width:820px;margin:0 auto 20px}
  h1 em{font-style:normal;color:var(--accent)}
  .sub{font-size:1.15rem;color:var(--ink-2);max-width:660px;margin:0 auto 34px}
  .hero-cta{display:flex;gap:14px;justify-content:center;flex-wrap:wrap}

  /* ---------- Sections ---------- */
  section{padding:80px 0}
  .sec-head{max-width:680px;margin-bottom:44px}
  .sec-head.center{margin-left:auto;margin-right:auto;text-align:center}
  .eyebrow{font-size:.8rem;font-weight:700;letter-spacing:.09em;text-transform:uppercase;color:var(--accent);margin-bottom:10px}
  h2{font-size:clamp(1.6rem,3.4vw,2.2rem);letter-spacing:-.02em;line-height:1.2;margin-bottom:14px;font-weight:750}
  .sec-head p{color:var(--ink-2)}
  .alt{background:var(--surface-2);border-top:1px solid var(--line);border-bottom:1px solid var(--line)}

  /* ---------- Stat tiles ---------- */
  .stats{display:grid;grid-template-columns:repeat(4,1fr);gap:16px}
  @media(max-width:900px){.stats{grid-template-columns:repeat(2,1fr)}}
  @media(max-width:520px){.stats{grid-template-columns:1fr}}
  .stat{
    background:var(--surface);border:1px solid var(--line);border-radius:var(--radius);
    padding:26px 22px;
  }
  .stat .n{font-size:2.3rem;font-weight:800;letter-spacing:-.03em;color:var(--ink);line-height:1.1}
  .stat .l{font-size:.92rem;color:var(--ink-2);margin-top:8px}
  .source{font-size:.82rem;color:var(--ink-3);margin-top:18px}

  /* ---------- Cards ---------- */
  .grid-3{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}
  @media(max-width:860px){.grid-3{grid-template-columns:1fr}}
  .card{
    background:var(--surface);border:1px solid var(--line);border-radius:var(--radius);
    padding:28px;
  }
  .card .ico{
    width:42px;height:42px;border-radius:11px;background:var(--accent-soft);
    display:flex;align-items:center;justify-content:center;margin-bottom:16px;
    color:var(--accent);font-size:1.2rem;font-weight:700;
  }
  .card h3{font-size:1.08rem;margin-bottom:8px;letter-spacing:-.01em}
  .card p{font-size:.95rem;color:var(--ink-2)}

  /* ---------- Steps (partenariats) ---------- */
  .steps{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-top:8px}
  @media(max-width:900px){.steps{grid-template-columns:repeat(2,1fr)}}
  @media(max-width:520px){.steps{grid-template-columns:1fr}}
  .step{position:relative;background:var(--surface);border:1px solid var(--line);border-radius:var(--radius);padding:24px 20px}
  .step .num{
    display:inline-flex;align-items:center;justify-content:center;
    width:30px;height:30px;border-radius:999px;background:var(--accent);color:#fff;
    font-weight:700;font-size:.9rem;margin-bottom:12px;
  }
  .step h4{font-size:1rem;margin-bottom:6px}
  .step p{font-size:.9rem;color:var(--ink-2)}
  .pledge{
    margin-top:28px;display:grid;grid-template-columns:repeat(3,1fr);gap:16px;
  }
  @media(max-width:860px){.pledge{grid-template-columns:1fr}}
  .pledge div{
    background:var(--accent-soft);border:1px solid var(--accent-line);
    border-radius:var(--radius);padding:20px 22px;font-size:.93rem;color:var(--ink);
  }
  .pledge strong{display:block;margin-bottom:4px;color:var(--accent)}
  .cta-band{
    margin-top:40px;background:var(--ink);color:#fff;border-radius:var(--radius);
    padding:38px 36px;display:flex;align-items:center;justify-content:space-between;
    gap:24px;flex-wrap:wrap;
  }
  .cta-band h3{font-size:1.3rem;letter-spacing:-.01em;margin-bottom:6px}
  .cta-band p{color:#cbd5e1;font-size:.95rem;max-width:520px}
  .cta-band .btn{background:#fff;color:var(--ink);white-space:nowrap}

  /* ---------- Investisseurs ---------- */
  .invest{display:grid;grid-template-columns:1.1fr .9fr;gap:44px;align-items:start}
  @media(max-width:860px){.invest{grid-template-columns:1fr}}
  .invest ul{list-style:none;display:flex;flex-direction:column;gap:16px;margin-top:6px}
  .invest li{
    display:flex;gap:14px;font-size:.98rem;color:var(--ink-2);
  }
  .invest li::before{
    content:"→";color:var(--accent);font-weight:700;flex:none;
  }
  .invest-panel{
    background:var(--gold-soft);border:1px solid #fde68a;border-radius:var(--radius);
    padding:30px;
  }
  .invest-panel h3{font-size:1.05rem;margin-bottom:12px;color:var(--gold)}
  .invest-panel p{font-size:.93rem;color:var(--ink-2);margin-bottom:18px}

  /* ---------- Formulaire contact ---------- */
  .form-wrap{max-width:640px;margin:0 auto}
  .form-card{background:var(--surface);border:1px solid var(--line);border-radius:var(--radius);padding:34px}
  .field{margin-bottom:18px}
  .field label{display:block;font-size:.88rem;font-weight:600;margin-bottom:6px}
  .field input,.field select,.field textarea{
    width:100%;padding:11px 14px;border:1px solid var(--line);border-radius:10px;
    font:inherit;font-size:.95rem;color:var(--ink);background:var(--surface);
  }
  .field input:focus,.field select:focus,.field textarea:focus{
    outline:none;border-color:var(--accent-line);box-shadow:0 0 0 3px var(--accent-soft);
  }
  .field textarea{min-height:130px;resize:vertical}
  .form-note{font-size:.82rem;color:var(--ink-3);margin-top:14px}
  .form-status{display:none;margin-top:16px;padding:12px 16px;border-radius:10px;font-size:.92rem}
  .form-status.ok{display:block;background:#ecfdf5;border:1px solid #a7f3d0;color:#065f46}
  .form-status.err{display:block;background:#fef2f2;border:1px solid #fecaca;color:#991b1b}
  /* Honeypot : hors écran, jamais display:none (certains bots le détectent) */
  .hp-field{position:absolute;left:-9999px;top:-9999px;height:1px;width:1px;overflow:hidden}

  /* ---------- Footer ---------- */
  footer{border-top:1px solid var(--line);padding:44px 0;font-size:.88rem;color:var(--ink-3)}
  .foot{display:flex;justify-content:space-between;gap:20px;flex-wrap:wrap}
  footer a{color:var(--ink-2)}
</style>
</head>
<body>

<header>
  <div class="wrap nav">
    <div class="logo">Mercure<span>-IA</span></div>
    <nav>
      <ul>
        <li class="hide-m"><a href="#solution">Solution</a></li>
        <li class="hide-m"><a href="#marche">Marché</a></li>
        <li class="hide-m"><a href="#partenariats">Partenariats data</a></li>
        <li class="hide-m"><a href="#investisseurs">Investisseurs</a></li>
        <li><a class="btn btn-primary" href="#contact">Nous contacter</a></li>
      </ul>
    </nav>
  </div>
</header>

<section class="hero">
  <div class="wrap">
    <span class="kicker">Intelligence artificielle souveraine · Secteur CHR</span>
    <h1>Toute la puissance de l'IA pour l'hôtellerie-restauration, <em>sans que vos données ne sortent de chez vous</em>.</h1>
    <p class="sub">Mercure-IA répond aux questions des dirigeants de cafés, hôtels et restaurants de façon autonome — sans aucun appel à des LLM externes. Vos chiffres, vos clients et votre stratégie restent dans votre entreprise.</p>
    <div class="hero-cta">
      <a class="btn btn-primary" href="#partenariats">Devenir partenaire data</a>
      <a class="btn btn-ghost" href="#investisseurs">Espace investisseurs</a>
    </div>
  </div>
</section>

<section id="marche" class="alt">
  <div class="wrap">
    <div class="sec-head center">
      <div class="eyebrow">Le marché</div>
      <h2>Le CHR a massivement adopté l'IA. Il attend une IA de confiance.</h2>
      <p>L'IA générative est devenue un outil de travail quotidien dans l'hôtellerie-restauration — mais la confidentialité des données reste l'un des premiers freins à son déploiement.</p>
    </div>
    <div class="stats">
      <div class="stat"><div class="n">79&nbsp;%</div><div class="l">des hôteliers utilisent l'IA générative au quotidien (68,8&nbsp;% des restaurateurs)</div></div>
      <div class="stat"><div class="n">92&nbsp;%</div><div class="l">des utilisateurs y ont davantage recours qu'en 2025 — une adoption qui s'accélère</div></div>
      <div class="stat"><div class="n">25,8&nbsp;%</div><div class="l">des hôteliers citent la sécurité et la confidentialité comme frein principal à l'IA</div></div>
      <div class="stat"><div class="n">61,9&nbsp;%</div><div class="l">placent l'IA et l'automatisation en tête de leurs investissements tech des 12 prochains mois</div></div>
    </div>
    <p class="source">Source : Étude Food Hotel Tech 2026 — 781 professionnels interrogés (444 hôteliers, 337 restaurateurs), salon Food Hotel Tech, Paris, avril 2026.</p>
  </div>
</section>

<section id="solution">
  <div class="wrap">
    <div class="sec-head">
      <div class="eyebrow">La solution</div>
      <h2>Une IA autonome, conçue pour le métier, souveraine par construction.</h2>
      <p>Là où les assistants généralistes envoient vos données vers des serveurs tiers, Mercure fonctionne en circuit fermé et parle le langage du CHR.</p>
    </div>
    <div class="grid-3">
      <div class="card">
        <div class="ico">◈</div>
        <h3>Zéro LLM externe</h3>
        <p>Mercure répond de façon autonome, sans appel à ChatGPT, Gemini ou tout autre modèle distant. Aucune donnée d'exploitation ne transite vers un tiers — la confidentialité n'est pas une option, c'est l'architecture.</p>
      </div>
      <div class="card">
        <div class="ico">◎</div>
        <h3>Expert du CHR</h3>
        <p>Entraînée sur des scénarios réels et anonymisés du secteur, Mercure comprend le RevPAR, le coefficient multiplicateur, les ratios matière, la saisonnalité — sans qu'il faille apprendre à « prompter ».</p>
      </div>
      <div class="card">
        <div class="ico">◍</div>
        <h3>Un copilote de direction</h3>
        <p>Pilotage, pricing, marge, RH, avis clients : Mercure répond aux questions que se posent réellement les dirigeants, à partir des données de leur établissement.</p>
      </div>
    </div>
  </div>
</section>

<section id="partenariats" class="alt">
  <div class="wrap">
    <div class="sec-head">
      <div class="eyebrow">Partenariats data — notre priorité</div>
      <h2>Partagez vos données. Construisons ensemble l'IA du secteur.</h2>
      <p>Mercure apprend à partir de <strong>scénarios anonymes</strong> construits avec des entreprises du CHR. Nous recherchons des hôtels, restaurants, groupes et éditeurs prêts à partager des jeux de données à étudier — dans un cadre contractuel strict, au bénéfice de tout le secteur.</p>
    </div>

    <div class="steps">
      <div class="step">
        <span class="num">1</span>
        <h4>Cadrage &amp; convention</h4>
        <p>Signature d'un accord de partage définissant le périmètre des données, leurs usages exclusifs et vos droits (NDA + convention de partenariat).</p>
      </div>
      <div class="step">
        <span class="num">2</span>
        <h4>Transfert sécurisé</h4>
        <p>Transmission chiffrée de vos jeux de données (exports PMS, caisse, planning, avis…) vers un environnement d'étude isolé.</p>
      </div>
      <div class="step">
        <span class="num">3</span>
        <h4>Anonymisation &amp; scénarios</h4>
        <p>Les données sont étudiées puis transformées en scénarios entièrement anonymisés : aucune donnée nominative, aucun établissement identifiable.</p>
      </div>
      <div class="step">
        <span class="num">4</span>
        <h4>Entraînement de Mercure</h4>
        <p>Seuls les scénarios anonymes servent à l'entraînement. Les données sources ne sont jamais intégrées au modèle ni conservées au-delà de l'étude.</p>
      </div>
    </div>

    <div class="pledge">
      <div><strong>Conformité RGPD</strong>Anonymisation irréversible avant tout entraînement, registre des traitements, droit de retrait à tout moment.</div>
      <div><strong>Vos données ne sont jamais revendues</strong>Elles ne servent qu'à la construction des scénarios d'étude, dans le périmètre défini par la convention.</div>
      <div><strong>Un retour concret pour les partenaires</strong>Accès anticipé à Mercure, restitution d'analyses sur vos propres données et visibilité en tant que partenaire fondateur.</div>
    </div>

    <div class="cta-band">
      <div>
        <h3>Vous disposez de données d'exploitation CHR ?</h3>
        <p>Hôtel, restaurant, groupe, franchise ou éditeur de logiciels : discutons d'un partenariat data. Premier échange sans engagement.</p>
      </div>
      <a class="btn js-contact" href="#contact" data-motif="partenariat">Proposer un jeu de données</a>
    </div>
  </div>
</section>

<section id="investisseurs">
  <div class="wrap">
    <div class="sec-head">
      <div class="eyebrow">Investisseurs</div>
      <h2>Un marché prêt à payer, un frein que nous sommes seuls à lever.</h2>
    </div>
    <div class="invest">
      <ul>
        <li><strong>Un budget déjà installé&nbsp;:</strong>&nbsp;58,6&nbsp;% des hôteliers et 62,7&nbsp;% des restaurateurs utilisateurs paient déjà au moins 20&nbsp;€/mois d'abonnement IA — près d'un quart dépassent 50&nbsp;€/mois.</li>
        <li><strong>Un investissement sectoriel massif&nbsp;:</strong>&nbsp;moins d'un professionnel sur dix ne prévoit aucun investissement tech sur 12 mois ; 42,7&nbsp;% des hôteliers engagent plus de 5&nbsp;000&nbsp;€ par an.</li>
        <li><strong>Un ROI démontré&nbsp;:</strong>&nbsp;près d'un hôtelier sur deux gagne au moins 2&nbsp;h par semaine grâce à l'IA ; plus d'un sur dix libère l'équivalent d'une journée complète.</li>
        <li><strong>Une différenciation défendable&nbsp;:</strong>&nbsp;la souveraineté des données (aucun appel à des LLM tiers) répond au frein sécurité/confidentialité que les acteurs généralistes ne peuvent pas lever par construction.</li>
      </ul>
      <div class="invest-panel">
        <h3>Rejoignez le tour de table</h3>
        <p>Nous préparons une levée d'amorçage pour financer la constitution du corpus de scénarios, l'entraînement du modèle et les premiers déploiements pilotes. Deck et projections financières disponibles sur demande.</p>
        <a class="btn btn-primary js-contact" href="#contact" data-motif="investisseur">Demander le deck investisseurs</a>
      </div>
    </div>
  </div>
</section>

<section id="contact" class="alt">
  <div class="wrap">
    <div class="sec-head center">
      <div class="eyebrow">Contact</div>
      <h2>Parlons de votre projet.</h2>
      <p>Partenariat data, investissement ou simple question : ce formulaire est notre canal de contact — il nous protège du spam et vous garantit une réponse.</p>
    </div>
    <div class="form-wrap">
      {#
        Formulaire branché sur ContactController (POST /contact) :
        CSRF + honeypot + time-trap serveur + RateLimiter + Validator.
        L'adresse de destination ne vit que dans .env (CONTACT_TO),
        jamais dans le HTML public (anti-moissonnage).
      #}
      <form class="form-card" id="contact-form" action="{{ path('app_contact') }}" method="post" novalidate>
        <input type="hidden" name="_token" value="{{ csrf_token('contact') }}">
        {# Time-trap horodaté CÔTÉ SERVEUR (ms) : pas de dérive d'horloge client #}
        <input type="hidden" name="form_ts" value="{{ 'now'|date('Uv') }}">
        <div class="hp-field" aria-hidden="true">
          <label for="website">Ne pas remplir ce champ</label>
          <input type="text" id="website" name="website" tabindex="-1" autocomplete="off">
        </div>
        <div class="field">
          <label for="motif">Vous êtes…</label>
          <select id="motif" name="motif" required>
            <option value="partenariat">Une entreprise CHR — partenariat data</option>
            <option value="investisseur">Un investisseur — demande de deck</option>
            <option value="autre">Autre demande</option>
          </select>
        </div>
        <div class="field">
          <label for="nom">Nom et prénom</label>
          <input type="text" id="nom" name="nom" required maxlength="120" autocomplete="name">
        </div>
        <div class="field">
          <label for="societe">Société / établissement</label>
          <input type="text" id="societe" name="societe" maxlength="120" autocomplete="organization">
        </div>
        <div class="field">
          <label for="email">E-mail professionnel</label>
          <input type="email" id="email" name="email" required maxlength="180" autocomplete="email">
        </div>
        <div class="field">
          <label for="message">Votre message</label>
          <textarea id="message" name="message" required maxlength="3000" placeholder="Décrivez votre demande — pour un partenariat data, précisez le type de données (PMS, caisse, avis clients…)."></textarea>
        </div>
        <button type="submit" class="btn btn-primary" style="border:none;cursor:pointer;width:100%">Envoyer ma demande</button>
        <div class="form-status" id="form-status" role="status"></div>
        <p class="form-note">Vos coordonnées ne servent qu'à traiter votre demande (RGPD). Aucune inscription à une newsletter sans votre accord explicite.</p>
      </form>
    </div>
  </div>
</section>

<footer>
  <div class="wrap foot">
    <div>© 2026 Mercure-IA — Groupe Horao. L'intelligence artificielle souveraine du CHR.</div>
    <div>
      <a href="#contact">Nous contacter</a>
      &nbsp;·&nbsp; Statistiques : Étude Food Hotel Tech 2026
    </div>
  </div>
</footer>

<script>
  // Pré-sélection du motif quand on arrive par un CTA (partenariat / investisseur).
  document.querySelectorAll('.js-contact').forEach(function(a){
    a.addEventListener('click', function(){
      var m = a.getAttribute('data-motif');
      var sel = document.getElementById('motif');
      if (m && sel) sel.value = m;
    });
  });

  // Envoi AJAX vers POST /contact (réponses JSON du contrôleur Symfony).
  var form = document.getElementById('contact-form');
  form.addEventListener('submit', async function(e){
    e.preventDefault();
    var status = document.getElementById('form-status');
    var btn = form.querySelector('button[type="submit"]');
    btn.disabled = true;
    status.className = 'form-status';
    status.textContent = '';
    try {
      var resp = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { 'Accept': 'application/json' }
      });
      var data = await resp.json();
      if (resp.ok && data.ok) {
        status.className = 'form-status ok';
        status.textContent = 'Merci ! Votre demande a bien été envoyée — nous revenons vers vous rapidement.';
        form.reset();
      } else if (resp.status === 422 && data.errors) {
        status.className = 'form-status err';
        status.textContent = Object.values(data.errors).join(' ');
      } else {
        status.className = 'form-status err';
        status.textContent = data.error || 'Une erreur est survenue, merci de réessayer.';
      }
    } catch (err) {
      status.className = 'form-status err';
      status.textContent = "Impossible d'envoyer la demande (problème réseau). Réessayez.";
    } finally {
      btn.disabled = false;
    }
  });
</script>
</body>
</html>
